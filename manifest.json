{
  "manifest_version": 3,
  "name": "Element Picker for AI Debugging",
  "version": "1.2.10",
  "description": "Hover, click, and multi-select page elements to instantly copy their HTML, CSS, and a ready-to-paste bug report for AI debugging.",
  "permissions": ["activeTab", "scripting", "storage", "clipboardWrite", "offscreen", "downloads"],
  "action": {
    "default_title": "Toggle Element Picker (Alt+Shift+E)",
    "default_icon": {
      "16": "icons/red/icon16.png",
      "48": "icons/red/icon48.png",
      "128": "icons/red/icon128.png"
    }
  },
  "icons": {
    "16": "icons/red/icon16.png",
    "48": "icons/red/icon48.png",
    "128": "icons/red/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["inject.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ],
  "commands": {
    "toggle-picker": {
      "suggested_key": {
        "default": "Alt+Shift+E"
      },
      "description": "Toggle the element picker on/off"
    }
  }
}
